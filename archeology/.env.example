# Sync-from-genesis experiment configuration.
# Copy this to `.env` and edit values. `.env` is gitignored.

# ─── Node layout ──────────────────────────────────────────────────────────
# Where the chain state + configs live. Inherited by poktrolld --home.
# Default: experiments/sync-from-genesis/datadir/.poktroll
NODE_HOME="${NODE_HOME:-$(pwd)/datadir/.poktroll}"

# Where FilePlugin writes block-{H}-meta + block-{H}-data files.
# This is the canonical archive we are extracting.
FILEPLUGIN_OUTPUT="${FILEPLUGIN_OUTPUT:-$(pwd)/fileplugin-output}"

# Where downloaded binaries are cached (one subdir per version).
BINARIES_DIR="${BINARIES_DIR:-$(pwd)/binaries}"

# Where per-version snapshot tarballs are written before upload.
SNAPSHOTS_DIR="${SNAPSHOTS_DIR:-$(pwd)/snapshots}"

# ─── Chain identity (do not change unless you know why) ───────────────────
CHAIN_ID="pocket"
MONIKER="pocketscribe-archeology"

# ─── Peering ──────────────────────────────────────────────────────────────
# Sauron PNF seed-two. Non-default P2P port (26663, not 26656).
PERSISTENT_PEERS="e3f1a09e045433199c94172ef0d6fc9ab7212ad7@seed-two.p2p.infra.pocket.network:26663"
SEEDS=""

# ─── RPC for status polling (orchestrator reads this) ─────────────────────
LOCAL_RPC="http://127.0.0.1:26657"

# ─── Sauron canonical endpoints (read-only, for verification) ─────────────
SAURON_RPC="https://sauron-rpc.infra.pocket.network"
SAURON_LCD="https://sauron-api.infra.pocket.network"

# ─── Run-time tuning ──────────────────────────────────────────────────────
# Polling interval (seconds) for the height-watcher that decides when to halt
HEIGHT_POLL_INTERVAL=10

# Grace period (seconds) after reaching target height before SIGINT-ing the node.
# We give the node a small window to write the last FilePlugin file pair
# atomically before shutdown.
HALT_GRACE_SECONDS=15

# Hard ceiling on how long a single version's sync can take (hours).
# If exceeded, orchestrator aborts the run with a clear error rather than
# letting it churn forever. 0 = no limit.
MAX_HOURS_PER_VERSION=0

# ─── Hetzner Object Storage (DEFERRED — set up after first run produces files) ───
# HETZNER_BUCKET="pocketscribe-mainnet-archeology"
# HETZNER_ENDPOINT="https://nbg1.your-objectstorage.com"
# HETZNER_REGION="nbg1"
# RCLONE_REMOTE="hetzner"
# # rclone config lives in ~/.config/rclone/rclone.conf; see configs/rclone-template.conf

# ── Hetzner Object Storage (snapshots upload) ────────────────────────────
# Get these from your Hetzner cloud console.
HETZNER_BUCKET=pocketscribe-mainnet-archeology
HETZNER_ENDPOINT=fsn1.your-objectstorage.com
HETZNER_REGION=fsn1
HETZNER_ACCESS_KEY=                 # populated in .env
HETZNER_SECRET_KEY=                 # populated in .env (NEVER commit)

# rclone remote name configured locally (see rclone config). Used by
# 50-upload-hetzner.sh as: rclone copy <file> $RCLONE_REMOTE:$HETZNER_BUCKET/
RCLONE_REMOTE=pocketscribe-hetzner
